<div class="trust-bar-fixed-container">
  <div class="container">
    <div class="trust-bar-grid-v6">
      <!-- 1. Envíos -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}truck.svg" alt="truck delivery">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">Envío en 24h o programado</strong>
          <span class="trust-subtitle-v6">Envíos programados 24/48h</span>
        </div>
      </div>
      <!-- 2. Descuento -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}money-bag.svg" alt="money bag">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">-8% dto. en cada pedido automático</strong>
          <span class="trust-subtitle-v6">hasta -10% dto. SIEMPRE</span>
        </div>
      </div>
      <!-- 3. Pago -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}lock.svg" alt="lock">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">Pago 100% Seguro</strong>
          <span class="trust-subtitle-v6">Tarjeta, Bizum, PayPal</span>
        </div>
      </div>
      <!-- 4. Atención -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}balloon.svg" alt="balloon">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">Atención Directa</strong>
          <span class="trust-subtitle-v6">WhatsApp y Teléfono</span>
        </div>
      </div>
    </div>
  </div>
</div>