<div class="trust-bar-fixed-container">
  <div class="container">
    <div class="trust-bar-grid-v6">
      <!-- 1. Envíos -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}truck.svg" alt="truck delivery">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">{l s='Envío en 24h-48h' d='Modules.Kpyhome.Shop'}</strong>
          <span class="trust-subtitle-v6">{l s='Envíos programados 24/48h' d='Modules.Kpyhome.Shop'}</span>
        </div>
      </div>
      <!-- 2. Descuento -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}gift.svg" alt="money bag">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">{l s='Envío gratis' d='Modules.Kpyhome.Shop'}</strong>
          <span class="trust-subtitle-v6">{l s='En península desde 39,90€' d='Modules.Kpyhome.Shop'}</span>
        </div>
      </div>
      <!-- 3. Pago -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}lock.svg" alt="lock">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">{l s='Pago 100% Seguro' d='Modules.Kpyhome.Shop'}</strong>
          <span class="trust-subtitle-v6">{l s='Tarjeta, Bizum, PayPal' d='Modules.Kpyhome.Shop'}</span>
        </div>
      </div>
      <!-- 4. Atención -->
      <div class="trust-item-v6">
        <div class="trust-icon-v6">
          <img src="{$module_img}balloon.svg" alt="balloon">
        </div>
        <div class="trust-content-v6">
          <strong class="trust-title-v6">{l s='Atención Directa' d='Modules.Kpyhome.Shop'}</strong>
          <span class="trust-subtitle-v6">{l s='WhatsApp y Teléfono, personas reales' d='Modules.Kpyhome.Shop'}</span>
        </div>
      </div>
    </div>
  </div>
</div>