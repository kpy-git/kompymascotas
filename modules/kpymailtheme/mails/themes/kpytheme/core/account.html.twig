                      <div style="font-family:Nunito, arial, sans-serif;font-size:18px;padding: 10px 25px;color:#363A41;font-weight: bold;">{{ '¡Enhorabuena!'|trans({}, 'Emails.Body', locale)|raw }}</div>
                      <!--[if mso | IE]></td></tr></table><![endif]-->
                    </td>
                  </tr>
                  <tr>
                    <td style="direction:{{ direction }};font-size:0px;padding:0 25px;text-align:left;">
