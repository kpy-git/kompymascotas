{% extends '@Modules/kpymailtheme/mails/themes/kpytheme/components/layout.html.twig' %}

{% block title %}{{ 'Account'|trans({}, 'Emails.Body', locale) }}{% endblock %}

{% block icon %}
<!--[if mso | IE]><table role="presentation" border="0" cellpadding="0" cellspacing="0"><tr><td class="" style="vertical-align:top;width:554px;" ><![endif]-->
<div class="mj-column-per-100 mj-outlook-group-fix" style="font-size:0px;text-align:{{ align_left }};direction:{{ direction }};display:inline-block;vertical-align:top;width:100%;">
  <table border="0" cellpadding="0" cellspacing="0" role="presentation" width="100%">
    <tbody>
    <tr>
      <td style="vertical-align:top;padding:0;">
        <table border="0" cellpadding="0" cellspacing="0" role="presentation" style="" width="100%">
          <tbody>
          <tr>
            <td align="center" style="margin: 30px 0;">
              <div class="icon-section">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none" style="width: 60px;height:60px;">
                  <!-- Sobre -->
                  <rect x="8" y="18" width="48" height="32" rx="2" fill="#FFF9E6" stroke="#F4C430" stroke-width="2"></rect>
                  <path d="M8 20 L32 36 L56 20" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
                  <!-- Check circle -->
                  <circle cx="48" cy="46" r="10" fill="#FF6B6B"></circle>
                  <path d="M44 46 L47 49 L52 43" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" fill="none"></path>
                </svg>
              </div>
            </td>
          </tr>
          </tbody>
        </table>
      </td>
    </tr>
    </tbody>
  </table>
</div>
{% endblock %}

