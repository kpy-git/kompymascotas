                      </p>

                      <p style="margin-top: 25px;">{{ 'Si decides no confirmar, no pasa nada. Simplemente no nos volverás a ver el pelo.'|trans({}, 'Emails.Body', locale) }}</p>
                    </div>
                  </div>
                  <!--[if mso | IE]></td></tr></table><![endif]-->
                </td>
              </tr>
              </tbody>
            </table>
