                <td style="direction:{{ direction }};font-size:0px;padding:0 25px;text-align:left;">
                  <div style="font-family:Nunito, arial, sans-serif;font-size:16px;padding: 10px 25px;color:#363A41;">
                    {{ 'Solo falta que confirmes tu email. Ya lo sabemos, es un rollo, pero si no lo haces no te podremos avisar cuando salga tu pedido (y tu perro se quedará esperando).'|trans({}, 'Emails.Body', locale)|raw }}
                  </div>
                </td>
              </tr>

              <tr>
                <td>
                  <div style="font-family:Nunito, arial, sans-serif;font-size:16px;padding: 10px 25px;color:#363A41;">
                    <div style="text-align: center;">
                      <a href="{verify_url}" class="cta-button">CONFIRMAR EMAIL</a>
                    </div>
                  </div>
                </td>
              </tr>

              <tr>
                <td style="direction:{{ direction }};font-size:0px;padding:0 25px;text-align:center;">
