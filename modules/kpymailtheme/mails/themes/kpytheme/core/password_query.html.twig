                                    <tbody>
                                      <tr>
                                        <td align="{{ align_left }}" style="font-size:0px;padding:10px 25px;word-break:break-word;">
                                          <div style="font-family:Nunito, arial, sans-serif;font-size:16px;line-height:25px;text-align:{{ align_left }};color:#363A41;">{{ 'Has solicitado cambiar tu contraseña, o eso parece.'|trans({}, 'Emails.Body', locale)|raw }}</div>
                                        </td>
                                      </tr>
                                      <tr>
                                        <td align="{{ align_left }}" style="font-size:0px;padding:10px 25px;word-break:break-word;">
