{% extends '@Modules/kpymailtheme/mails/themes/kpytheme/components/layout.html.twig' %}
        
{% block title %}{{ 'Password Query'|trans({}, 'Emails.Body', locale) }}{% endblock %}

{% block icon %}

<div class="icon-section">
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" fill="none">
    <!-- Candado base -->
    <rect x="25" y="35" width="30" height="25" rx="3" fill="#2C5F7D"></rect>
    <rect x="27" y="37" width="26" height="21" rx="2" fill="#3d7a9e"></rect>
    <!-- Arco del candado -->
    <path d="M 32 35 L 32 25 Q 32 18, 40 18 Q 48 18, 48 25 L 48 35" stroke="#2C5F7D" stroke-width="4" fill="none" stroke-linecap="round"></path>
    <!-- Cerradura -->
    <circle cx="40" cy="47" r="3" fill="#F4C430"></circle>
    <rect x="38.5" y="47" width="3" height="6" rx="1" fill="#F4C430"></rect>
    <!-- Flecha circular de reset -->
    <path d="M 60 25 Q 70 25, 70 35 Q 70 45, 60 45" stroke="#FF6B6B" stroke-width="3" fill="none" stroke-linecap="round"></path>
    <path d="M 60 22 L 60 28 L 54 25 Z" fill="#FF6B6B"></path>
    <!-- Punto decorativo -->
    <circle cx="40" cy="15" r="2" fill="#F4C430" opacity="0.6"></circle>
  </svg>
</div>
  {{ parent() }}
{% endblock %}


{% block content %}
