  {{ 'Para la próxima, prueba con algo fácil de recordar pero difícil de adivinar. Tipo "MiPerroSeComio7Calcetines" (pero no uses esa, que ahora ya la sabe todo el mundo).'|trans({}, 'Emails.Body', locale) }}
{% endblock %}
