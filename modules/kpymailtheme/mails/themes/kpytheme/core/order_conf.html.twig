                                </div>

                                <div class="summary-row">
                                    <span class="summary-label">{{ 'Gastos de envío:'|trans({}, 'Emails.Body', locale)|raw }}</span>
                                    <span class="summary-amount">{total_shipping}</span>
                                </div>

                                <div class="summary-row total">
                                    <span class="summary-label">{{ 'TOTAL PAGADO:'|trans({}, 'Emails.Body', locale)|raw }}</span>
