{% extends '@Modules/kpymailtheme/mails/themes/kpytheme/components/layout.html.twig' %}
        
{% block title %}{{ 'Order confirmation'|trans({}, 'Emails.Body', locale) }}{% endblock %}

{% block icon %}
<div class="icon-section">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 64 64" fill="none">
        <rect x="12" y="24" width="40" height="28" rx="2" fill="#FFF9E6" stroke="#F4C430" stroke-width="2"></rect>
        <path d="M12 24 L32 12 L52 24" stroke="#F4C430" stroke-width="2" stroke-linejoin="round" fill="#FF6B6B" opacity="0.3"></path>
        <line x1="12" y1="24" x2="52" y2="24" stroke="#F4C430" stroke-width="2"></line>
        <line x1="32" y1="24" x2="32" y2="52" stroke="#F4C430" stroke-width="2"></line>
        <circle cx="48" cy="48" r="10" fill="#FF6B6B"></circle>
        <path d="M44 48 L47 51 L52 45" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"></path>
    </svg>
</div>

{{ parent() }}
{% endblock %}

