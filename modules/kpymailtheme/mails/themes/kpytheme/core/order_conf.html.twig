                                            </tr>
                                          </tbody>
                                        </table>
                                      </td>
                                      <td class="box">
                                        <table class="table" style="width:100%">
                                          <tbody>
                                            <tr>
                                              <td>
                                                <div class="address-box">
                                                    <h3>📄 {{ 'Dirección de facturación'|trans({}, 'Emails.Body', locale)|raw }}</h3>
                                                  {% if templateType == 'html' %}
                                                    {invoice_block_html}
                                                  {% endif %}
                                                  {% if templateType == 'txt' %}
                                                    {invoice_block_txt}
                                                  {% endif %}
                                                </div>
                                              </td>
                                            </tr>
                                          </tbody>
                                        </table>
                                      </td>
                                    </tr>
                                  </table>
                                </td>
                              </tr>
                            </tbody>
                          </table>
                        </div>
