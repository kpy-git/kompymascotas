{% block styles %}
<style type="text/css">
    #outlook a {
      padding: 0;
    }

    body {
      margin: 0;
      padding: 0;
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }

    table,
    td {
      border-collapse: collapse;
      mso-table-lspace: 0pt;
      mso-table-rspace: 0pt;
    }

    img {
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
      -ms-interpolation-mode: bicubic;
    }

    p {
      display: block;
      margin: 13px 0;
    }

    .status-box {
      background-color: #fff0f0;
      border: 2px solid #ffcccc;
      border-radius: 10px;
      padding: 22px 26px;
      margin: 0 0 24px 0;
    }

    .status-box h2 {
      margin: 0 0 10px 0;
      font-size: 19px;
      color: #cc4444;
      font-weight: 700;
    }

    .status-box p {
      margin: 0;
      font-size: 15px;
      color: #333;
      line-height: 1.6;
    }
    .steps-box {
      background-color: #f7f7f7;
      border: 2px solid #e5e5e5;
      border-radius: 10px;
      padding: 22px 26px;
      margin: 0 0 28px 0;
    }
    .steps-box h3 {
      margin: 0 0 14px 0;
      font-size: 17px;
      color: #2C5F7D;
      font-weight: 700;
    }
    .steps-box ul {
      margin: 0;
      padding: 0;
      list-style: none;
    }
    .steps-box ul li {
      position: relative;
      padding: 9px 0 9px 30px;
      font-size: 15px;
      line-height: 1.55;
      color: #333;
      border-bottom: 1px dashed #e0e0e0;
    }
    .steps-box ul li::before {
      content: ">";
      position: absolute;
      left: 0;
      top: 9px;
      color: #FF6B6B;
      font-weight: 900;
      font-size: 16px;
    }
    .cta-wrap {
      text-align: center;
      margin: 0 0 14px 0;
    }
    .cta-btn {
      display: inline-block;
      background-color: #FF6B6B;
      color: #ffffff;
      text-decoration: none;
      padding: 16px 40px;
      border-radius: 10px;
      font-size: 16px;
      font-weight: 800;
      letter-spacing: 0.4px;
      text-transform: uppercase;
      box-shadow: 0 4px 14px rgba(255,107,107,0.28);
    }

  </style>
