{% block title %}{{ 'Payment Error'|trans({}, 'Emails.Body', locale) }}{% endblock %}

{% block icon %}
  <div class="icon-section">
    <svg xmlns="http://www.w3.org/2000/svg" width="76" height="76" viewBox="0 0 76 76" fill="none">
      <!-- fondo suave -->
      <circle cx="38" cy="38" r="36" fill="#fff0f0" stroke="#ffcccc" stroke-width="2"></circle>
      <!-- tarjeta -->
      <rect x="16" y="24" width="44" height="28" rx="5" fill="#2C5F7D"></rect>
      <rect x="16" y="30" width="44" height="8" fill="#3d7a9e"></rect>
      <rect x="22" y="42" width="14" height="5" rx="2.5" fill="#FFF9E6" opacity="0.9"></rect>
      <rect x="42" y="42" width="8" height="5" rx="2.5" fill="#FFF9E6" opacity="0.5"></rect>
      <!-- señal de error (triangulo) -->
      <path d="M52 15 L62 33 L42 33 Z" fill="#FF6B6B"></path>
      <line x1="52" y1="20" x2="52" y2="28" stroke="white" stroke-width="2.5" stroke-linecap="round"></line>
      <circle cx="52" cy="31" r="1.5" fill="white"></circle>
    </svg>
  </div>
  {{ parent() }}
{% endblock %}

