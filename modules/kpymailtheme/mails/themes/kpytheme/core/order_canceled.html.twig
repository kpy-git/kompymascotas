    .moz-text-html .mj-column-px-25 {
      width: 25px !important;
      max-width: 25px;
    }
  </style>
  <style type="text/css">
  </style>
  <style type="text/css">
    .shadow {
      box-shadow: 0 20px 30px 0 rgba(0, 0, 0, 0.1);
    }

    .label {
      font-weight: 700;
    }

    .warning {
      font-weight: 700;
      font-size: 16px;
    }

    a {
      color: #25B9D7;
      text-decoration: underline;
      font-weight: 600;
    }

    a.light {
      font-weight: 400;
    }

    span.strong {
      font-weight: 600;
    }

    .order-cancelled-box {
      background-color: #f8f8f8;
      border: 2px solid #e0e0e0;
      padding: 25px 30px;
      border-radius: 10px;
      text-align: center;
      margin: 30px 0;
      font-size: 16px;
      font-family: Nunito, sans-serif, arial;
    }

    .order-cancelled-box .order-number {
      font-size: 28px;
      font-weight: 700;
      color: #2C5F7D;
      margin: 5px 0 10px 0;
    }

    .order-cancelled-box .status {
      display: inline-block;
      background-color: #ffe5e5;
      color: #cc5555;
      padding: 8px 20px;
      border-radius: 20px;
      font-size: 14px;
      font-weight: 600;
      margin-top: 10px;
    }

    @media only screen and (max-width: 480px) {

      body,
      .no-bg {
