{% block styles %}
<style type="text/css">
    #outlook a {
      padding: 0;
    }

    body {
      margin: 0;
      padding: 0;
      -webkit-text-size-adjust: 100%;
      -ms-text-size-adjust: 100%;
    }

    table,
    td {
      border-collapse: collapse;
      mso-table-lspace: 0pt;
      mso-table-rspace: 0pt;
    }

    img {
      border: 0;
      height: auto;
      line-height: 100%;
      outline: none;
      text-decoration: none;
      -ms-interpolation-mode: bicubic;
    }

    p {
      display: block;
      margin: 13px 0;
    }

    .refund-box {
      background-color: #FFF9E6;
      border-left: 4px solid #F4C430;
      padding: 20px 25px;
      border-radius: 8px;
      margin: 25px 0;
      font-size: 14px;
      font-family: Nunito,sans-serif,arial;
      color: #363A41;
      line-height: 25px;
    }

    .alert-box {
      background: linear-gradient(135deg, #fff0f0 0%, #ffe8e8 100%);
      border: 2px solid #ffcccc;
      padding: 22px 28px;
      border-radius: 10px;
      margin: 30px 0;
      font-size: 14px;
      font-family: Nunito,sans-serif,arial;
      color: #363A41;
      line-height: 25px;
    }
    .alert-box a {
      color: #cc5555;
      text-decoration: underline;
      font-weight: 700;
    }
    .alert-box h3 {
      margin: 0 0 12px 0;
      font-size: 18px;
      color: #cc5555;
      font-weight: 600;
    }
  </style>
  <!--[if mso]>
        <noscript>
        <xml>
