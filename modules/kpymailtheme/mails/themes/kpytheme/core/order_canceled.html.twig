{% endblock %}

{% block posdata_message %}{{ 'Si quieres volver a comprar, nosotros seguiremos ahí. Sin rencores. Si no, te deseamos lo mejor a ti y tu peludo.'|trans({}, 'Emails.Body', locale) }}{% endblock %}