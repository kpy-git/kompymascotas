{% block styles %}
<style type="text/css">
    #outlook a {
        padding: 0;
    }

    body {
        margin: 0;
        padding: 0;
        -webkit-text-size-adjust: 100%;
        -ms-text-size-adjust: 100%;
    }

    table,
    td {
        border-collapse: collapse;
        mso-table-lspace: 0pt;
        mso-table-rspace: 0pt;
    }

    img {
        border: 0;
        height: auto;
        line-height: 100%;
        outline: none;
        text-decoration: none;
        -ms-interpolation-mode: bicubic;
    }

    p {
        display: block;
        margin: 13px 0;
    }

    .cta-button-large {
        display: inline-block;
        background-color: #FF6B6B;
        color: #ffffff !important;
        text-decoration: none;
        padding: 18px 45px;
        border-radius: 10px;
        font-weight: 700;
        margin: 20px 0;
        transition: all 0.3s ease;
        box-shadow: 0 4px 15px rgba(255, 107, 107, 0.3);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        font-size: 18px;
        font-family: Nunito, Arial, sans-serif;
    }

    .help-section {
        background-color: #FFF9E6;
        padding: 22px 28px;
        border-radius: 10px;
        margin: 0;
        border-left: 5px solid #F4C430;
        font-size: 15px;
        font-family: Nunito, Arial, sans-serif;
    }

    .help-section a {
        color: #FF6B6B;
        text-decoration: none;
        font-weight: bold;
    }

    .help-section h3 {
        margin: 0 0 12px 0;
        font-size: 18px;
        color: #2C5F7D;
        font-weight: bold;
    }
    .label {
         font-weight: bold;
     }

    .update-note {
        background-color: #f0f7ff;
        border-left: 5px solid #4A90E2;
        padding: 15px 20px;
        border-radius: 6px;
        margin: 20px 0;
        font-size: 14px;
        color: #666666;
        line-height: 1.5;
        font-family: Nunito, Arial, sans-serif;
    }

    .features-box {
        background-color: #f8f8f8;
        padding: 25px 30px;
        border-radius: 10px;
        margin: 30px 0;
        border: 2px solid #e8e8e8;
        font-family: Nunito, Arial, sans-serif;
    }

    .features-box h3 {
        margin: 0 0 18px 0;
        font-size: 17px;
        color: #2C5F7D;
        font-weight: bold;
    }

    .features-list {
        margin: 0;
        padding: 0;
        list-style: none;
    }

    .features-list li {
        padding: 10px 0 10px 30px;
        position: relative;
        font-size: 15px;
        line-height: 1.5;
        color: #333333;
    }

    .features-list li::before {
        content: "-";
        position: absolute;
        left: 0;
        top: 10px;
        color: #FF6B6B;
        font-weight: bold;
        font-size: 18px;
    }

    </style>
{% endblock %}
{% endblock %}

{% block posdata_message %}
    {{ 'Si el mensajero no te encuentra, lo normal es que lo intenten 2 veces. Pero estate pendiente del móvil por si te llaman (a veces llaman desde números raros).'|trans({}, 'Emails.Body', locale)|raw }}
{% endblock %}