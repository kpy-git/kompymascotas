{% block title %}{{ 'Preparado para envío'|trans({}, 'Emails.Body', locale) }}{% endblock %}

{% block icon %}
<div class="icon-section">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 80 80" fill="none">
        <!-- Camión -->
        <rect x="8" y="28" width="35" height="22" rx="2" fill="#2C5F7D"></rect>
        <rect x="43" y="35" width="20" height="15" rx="2" fill="#2C5F7D"></rect>
        <path d="M43 35 L43 50 L63 50 L63 42 L55 35 Z" fill="#3d7a9e"></path>
        <!-- Ventanas -->
        <rect x="12" y="32" width="8" height="7" rx="1" fill="#FFF9E6"></rect>
        <rect x="23" y="32" width="8" height="7" rx="1" fill="#FFF9E6"></rect>
        <rect x="47" y="38" width="10" height="7" rx="1" fill="#FFF9E6"></rect>
        <!-- Ruedas -->
        <circle cx="18" cy="50" r="5" fill="#333333"></circle>
        <circle cx="18" cy="50" r="3" fill="#666666"></circle>
        <circle cx="53" cy="50" r="5" fill="#333333"></circle>
        <circle cx="53" cy="50" r="3" fill="#666666"></circle>
        <!-- Paquete en la parte trasera -->
        <rect x="14" y="35" width="12" height="10" rx="1" fill="#F4C430" opacity="0.9"></rect>
        <line x1="17" y1="35" x2="17" y2="45" stroke="#FF6B6B" stroke-width="1.5"></line>
        <line x1="14" y1="40" x2="26" y2="40" stroke="#FF6B6B" stroke-width="1.5"></line>
        <!-- Líneas de movimiento -->
        <line x1="2" y1="32" x2="6" y2="32" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round" opacity="0.6"></line>
        <line x1="1" y1="38" x2="7" y2="38" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round" opacity="0.6"></line>
        <line x1="2" y1="44" x2="6" y2="44" stroke="#FF6B6B" stroke-width="2" stroke-linecap="round" opacity="0.6"></line>
    </svg>
</div>
{{ parent() }}
{% endblock %}

