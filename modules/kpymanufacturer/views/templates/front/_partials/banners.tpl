<section class="promos-section section-gap--sm">
    <div class="container">

        <h2 class="section-title" style="margin-bottom:6px; text-align:center;">{l s='Featured Promotions' d='Modules.Kpymanufacturer.Shop'}</h2>
        <p class="section-sub" style="margin-bottom:28px; text-align:center;">{l s='The best deals from this brand, handpicked just for you.' d='Modules.Kpymanufacturer.Shop'}</p>

        <!-- BANNER PRINCIPAL — Desktop: 1200×400px | Mobile: 640×200px -->
        <!-- Reemplazar el div.banner-placeholder por <a href="URL"><img src="banner.jpg" alt="Descripción" /></a> -->
        <div class="banner-placeholder banner-placeholder--main">
            <div class="banner-placeholder__inner">
                <span class="banner-placeholder__icon">🖼️</span>
                <div class="banner-placeholder__info">
                    <strong>Banner principal de marca</strong>
                    <span>Tamaño recomendado: <b>1200 × 400 px</b> (desktop) · <b>640 × 200 px</b> (móvil)</span>
                    <span>Formato: JPG/WebP · Peso máx: 150 KB</span>
                </div>
            </div>
        </div>

        <!-- BANNERS SECUNDARIOS — Desktop: 580×280px | Mobile: 640×280px (full width) -->
        <div class="promos-grid">

            <div class="banner-placeholder banner-placeholder--secondary">
                <div class="banner-placeholder__inner">
                    <span class="banner-placeholder__icon">🖼️</span>
                    <div class="banner-placeholder__info">
                        <strong>Banner secundario 1</strong>
                        <span>Tamaño: <b>580 × 280 px</b></span>
                    </div>
                </div>
            </div>

            <div class="banner-placeholder banner-placeholder--secondary">
                <div class="banner-placeholder__inner">
                    <span class="banner-placeholder__icon">🖼️</span>
                    <div class="banner-placeholder__info">
                        <strong>Banner secundario 2</strong>
                        <span>Tamaño: <b>580 × 280 px</b></span>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>